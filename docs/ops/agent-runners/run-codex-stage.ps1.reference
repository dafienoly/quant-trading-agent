param(
  [Parameter(Mandatory=$true)]
  [string]$Stage
)

$ErrorActionPreference = "Stop"

$repoCandidates = @(
  $env:GITHUB_WORKSPACE,
  "D:\actions-runner\_work\quant-trading-agent\quant-trading-agent",
  "D:\Repo\quant-trading-agent",
  (Get-Location).Path
) | Where-Object { $_ -and (Test-Path $_) }

if (-not $repoCandidates -or $repoCandidates.Count -eq 0) {
  Write-Error "Cannot locate repository workspace. GITHUB_WORKSPACE='$env:GITHUB_WORKSPACE'"
  exit 2
}

$repo = $repoCandidates[0]
Set-Location $repo
Write-Host "Using repository workspace: $repo"

$handoff = Join-Path ".agent\handoff" "$Stage.md"
if (!(Test-Path $handoff)) {
  Write-Error "Missing handoff: $handoff"
  exit 2
}

$statePath = ".agent\state.json"
if (!(Test-Path $statePath)) {
  Write-Error "Missing pipeline state: $statePath"
  exit 2
}

$state = Get-Content $statePath -Raw -Encoding UTF8 | ConvertFrom-Json
$featureId = $state.feature_id
if (-not $featureId) {
  Write-Error "Missing feature_id in .agent/state.json"
  exit 2
}

$today = Get-Date -Format "yyyy-MM-dd"
$handoffText = Get-Content $handoff -Raw -Encoding UTF8
$previewLength = [Math]::Min(1200, $handoffText.Length)
$handoffPreview = $handoffText.Substring(0, $previewLength)

function Write-Utf8Markdown {
  param(
    [Parameter(Mandatory=$true)]
    [string]$Path,
    [Parameter(Mandatory=$true)]
    [object[]]$Lines
  )
  $parent = Split-Path -Parent $Path
  if ($parent) {
    New-Item -ItemType Directory -Force -Path $parent | Out-Null
  }
  Set-Content -Path $Path -Value ($Lines -join [Environment]::NewLine) -Encoding UTF8
  Write-Host "Generated $Path"
}

switch ($Stage) {
  "codex_pm" {
    $outPath = "docs\requirements\$today-$featureId-requirements.md"
    $lines = @(
      "# $featureId Requirements",
      "",
      "> Smoke-test document generated by local Codex wrapper.",
      "> This file proves GitHub Actions can call the local Windows Codex PM stage command.",
      "",
      "## Stage",
      "",
      "codex_pm",
      "",
      "## Source Handoff",
      "",
      $handoff,
      "",
      "## User Goal",
      "",
      "This is a temporary smoke-test requirements document. Replace this wrapper with the real Codex command after the command chain is verified.",
      "",
      "## Functional Requirements",
      "",
      "| ID | Requirement | Acceptance Criteria | Priority |",
      "|---|---|---|---|",
      "| F-001 | Verify local Codex PM command execution | Workflow calls the local wrapper and writes this requirements file | MUST |",
      "",
      "## Acceptance Criteria",
      "",
      "- The workflow can call ``C:\agent-runners\run-codex-stage.ps1``.",
      "- The script can read ``.agent/state.json``.",
      "- The script can read ``.agent/handoff/codex_pm.md``.",
      "- The script can write a requirements document under ``docs/requirements/``.",
      "",
      "## Handoff Preview",
      "",
      "````text",
      $handoffPreview,
      "````"
    )
    Write-Utf8Markdown -Path $outPath -Lines $lines
  }
  "codex_architect" {
    $requirementsPath = "docs\requirements\$today-$featureId-requirements.md"
    $outPath = "docs\design\$today-$featureId-architecture.md"
    $requirementsStatus = if (Test-Path $requirementsPath) { "found: $requirementsPath" } else { "not found at expected path: $requirementsPath" }
    $lines = @(
      "# $featureId Architecture",
      "",
      "> Smoke-test architecture document generated by local Codex wrapper.",
      "> This file proves GitHub Actions can call the local Windows Codex Architect stage command.",
      "",
      "## Stage",
      "",
      "codex_architect",
      "",
      "## Source Handoff",
      "",
      $handoff,
      "",
      "## Upstream Requirements",
      "",
      $requirementsStatus,
      "",
      "## Architecture Summary",
      "",
      "This smoke-test architecture keeps the implementation intentionally minimal. It does not change trading, risk, execution, broker, account, strategy, data-provider, or live-trading modules.",
      "",
      "## Module Plan",
      "",
      "| Module | Responsibility |",
      "|---|---|",
      "| ``.agent/`` | Pipeline state and handoff files |",
      "| ``docs/requirements/`` | Codex A PM output |",
      "| ``docs/design/`` | Codex B architecture output |",
      "",
      "## Development Guidance for Claude Team",
      "",
      "- Claude Code A may create a team plan from this smoke-test architecture.",
      "- Claude Code B/C should not modify production trading code for this smoke test.",
      "- Any later real feature must replace this smoke-test document with real architecture content.",
      "",
      "## Safety Impact",
      "",
      "No real trading capability is affected. No risk, execution, broker, account, or order logic is touched.",
      "",
      "## Handoff Preview",
      "",
      "````text",
      $handoffPreview,
      "````"
    )
    Write-Utf8Markdown -Path $outPath -Lines $lines
  }
  "codex_reviewer" {
    $outPath = "docs\review\$today-$featureId-codex-review-r1.md"

    # Try real Codex mode when AGENT_REAL_CODEX_REVIEWER=true or AGENT_REAL_CODEX_REVIEWER_STRICT=true
    $useReal = $env:AGENT_REAL_CODEX_REVIEWER -eq "true"
    $useStrict = $env:AGENT_REAL_CODEX_REVIEWER_STRICT -eq "true"
    if ($useReal -or $useStrict) {
      # ----------------------------------------------------------------
      # Artifact Manifest Resolver
      # Priority: gate JSON found fields > state.json required_docs > glob
      # ----------------------------------------------------------------
      $manifest = @{
        feature_id = $featureId
        artifacts  = @{}
        missing    = @()
      }

      # Gate files (in priority order per artifact)
      $gateFiles = @{
        "requirements"     = @("claude_lead_review_gate.json", "phase_dev_gate.json", "phase_test_gate.json", "codex_review_gate.json")
        "architecture"     = @("claude_lead_review_gate.json", "phase_dev_gate.json", "phase_test_gate.json", "codex_review_gate.json")
        "team_plan"        = @("claude_lead_review_gate.json", "phase_dev_gate.json", "phase_test_gate.json", "codex_review_gate.json")
        "phase_dev"        = @("phase_dev_gate.json", "phase_test_gate.json", "codex_review_gate.json")
        "phase_test"       = @("phase_test_gate.json", "codex_review_gate.json")
        "claude_lead_review" = @("claude_lead_review_gate.json", "codex_review_gate.json")
      }
      $gateFoundKeys = @{
        "requirements"     = "pm"
        "architecture"     = "architecture"
        "team_plan"        = "team_plan"
        "phase_dev"        = "phase_dev"
        "phase_test"       = "phase_test"
        "claude_lead_review" = "claude_lead_review"
      }

      foreach ($key in $gateFiles.Keys) {
        $resolvedPath = $null
        $sourceDesc = ""
        $candidateGates = $gateFiles[$key]
        $foundKey = $gateFoundKeys[$key]

        # Priority 1: gate JSON found fields
        foreach ($gName in $candidateGates) {
          $gFile = ".agent\gates\$gName"
          if (Test-Path $gFile) {
            $gContent = Get-Content $gFile -Raw -Encoding UTF8 | ConvertFrom-Json
            if ($gContent.found -and $gContent.found.$foundKey) {
              $paths = $gContent.found.$foundKey
              if ($paths.Count -gt 0 -and $paths[0]) {
                $resolvedPath = $paths[0] -replace '\\', '/'  # normalize backslash
                $sourceDesc = ".agent\gates\$gName found.$foundKey"
                break
              }
            }
          }
        }

        # Priority 2: state.json required_docs
        if (-not $resolvedPath -and $state.required_docs) {
          $stateKey = $key
          if ($key -eq "claude_lead_review") { $stateKey = "claude_lead_review" }
          if ($state.required_docs.$stateKey) {
            $resolvedPath = $state.required_docs.$stateKey -replace '\\', '/'
            $sourceDesc = ".agent/state.json required_docs.$stateKey"
          }
          # Also check phase_*_report_pattern
          if (-not $resolvedPath -and $key -eq "phase_dev" -and $state.required_docs.phase_dev_report_pattern) {
            $phaseNum = if ($state.team_pipeline) { $state.team_pipeline.current_phase } else { 1 }
            $resolvedPath = ($state.required_docs.phase_dev_report_pattern -replace '<n>', $phaseNum) -replace '\\', '/'
            $sourceDesc = ".agent/state.json phase_dev_report_pattern"
          }
          if (-not $resolvedPath -and $key -eq "phase_test" -and $state.required_docs.phase_test_report_pattern) {
            $phaseNum = if ($state.team_pipeline) { $state.team_pipeline.current_phase } else { 1 }
            $resolvedPath = ($state.required_docs.phase_test_report_pattern -replace '<n>', $phaseNum) -replace '\\', '/'
            $sourceDesc = ".agent/state.json phase_test_report_pattern"
          }
        }

        # Priority 3: glob fallback
        if (-not $resolvedPath) {
          $patterns = @()
          switch ($key) {
            "requirements"     { $patterns = @("*$featureId*requirements*", "*$featureId*pm*") }
            "architecture"     { $patterns = @("*$featureId*architecture*", "*$featureId*arch*") }
            "team_plan"        { $patterns = @("*$featureId*team-plan*", "*$featureId*team_plan*") }
            "phase_dev"        { $patterns = @("*$featureId*dev-report*", "*$featureId*phase-*-dev*") }
            "phase_test"       { $patterns = @("*$featureId*test-report*", "*$featureId*phase-*-test*") }
            "claude_lead_review" { $patterns = @("*$featureId*lead-review*", "*$featureId*claude-lead*") }
          }
          $globDirs = @("docs\requirements", "docs\design", "docs\dev_plans", "docs\dev_reports", "docs\test_reports", "docs\review")
          foreach ($pat in $patterns) {
            foreach ($dir in $globDirs) {
              $matches = Get-ChildItem -Path "$dir\$pat" -ErrorAction SilentlyContinue
              if ($matches) {
                $resolvedPath = $matches[0].FullName -replace '\\', '/' -replace '^.*?(docs/)', '$1'
                $sourceDesc = "glob $dir\$pat"
                break
              }
            }
            if ($resolvedPath) { break }
          }
        }

        $exists = $false
        if ($resolvedPath) {
          $exists = Test-Path $resolvedPath
        }

        if ($resolvedPath) {
          $manifest.artifacts[$key] = @{ path = $resolvedPath; source = $sourceDesc; exists = $exists }
        } else {
          $manifest.missing += $key
        }
      }

      # Write artifact manifest for downstream use
      $manifestDir = ".agent"
      $manifestPath = Join-Path $manifestDir "artifact_manifest_codex_reviewer.json"
      New-Item -ItemType Directory -Force -Path $manifestDir | Out-Null
      $manifestJson = $manifest | ConvertTo-Json -Depth 5
      [System.IO.File]::WriteAllText([System.IO.Path]::GetFullPath($manifestPath), $manifestJson, [System.Text.UTF8Encoding]::new($false))
      Write-Host "Generated $manifestPath"

      # Build prompt parts with resolved artifact paths
      $promptLines = @()

      $promptLines += "Generate a Codex review report (R1) in Markdown format. Output ONLY the raw Markdown content to stdout — do NOT write any file, do NOT use any tools, do NOT include conversational text, greetings, or meta-commentary."
      $promptLines += ""
      $promptLines += "## Context"
      $promptLines += ""
      $promptLines += "### Current Stage"
      $promptLines += "codex_reviewer — You are Codex B (Architect Reviewer). You are NOT a developer, tester, or PM. You perform independent code/process/safety review."
      $promptLines += ""
      $promptLines += "### Feature ID"
      $promptLines += $featureId
      $promptLines += ""
      $promptLines += "### Handoff Content (from claude_lead_review stage)"
      $promptLines += ""
      $promptLines += $handoffText
      $promptLines += ""
      $promptLines += "### Pipeline State"
      $promptLines += ""
      $promptLines += (Get-Content $statePath -Raw -Encoding UTF8)
      $promptLines += ""

      # Build Resolved Artifact Manifest table
      $promptLines += "## Resolved Artifact Manifest"
      $promptLines += ""
      $promptLines += "IMPORTANT: Do NOT infer artifact paths from date strings or patterns below."
      $promptLines += "Use this manifest as the source of truth. If an artifact is listed as exists=true,"
      $promptLines += "it exists at the path shown — do NOT claim it is missing."
      $promptLines += ""
      $promptLines += "| Artifact | Path | Source | Exists |"
      $promptLines += "|---|---|---|---|"
      foreach ($artKey in @("requirements", "architecture", "team_plan", "phase_dev", "phase_test", "claude_lead_review")) {
        $a = $manifest.artifacts[$artKey]
        if ($a) {
          $promptLines += "| $artKey | $($a.path) | $($a.source) | $($a.exists) |"
        } else {
          $promptLines += "| $artKey | (missing) | - | false |"
        }
      }
      $promptLines += ""

      # Include artifact content using resolved paths
      function Add-ArtifactContent {
        param([string]$Key, [string]$Label)
        $a = $manifest.artifacts[$Key]
        if ($a -and $a.exists -and (Test-Path $a.path)) {
          $promptLines += (Get-Content $a.path -Raw -Encoding UTF8)
        } else {
          $status = if ($a) { "exists=$($a.exists), path=$($a.path), source=$($a.source)" } else { "artifact key not in manifest" }
          $promptLines += "($Label file — $status)"
        }
        $promptLines += ""
      }

      $promptLines += "### Requirements Document"
      $promptLines += ""
      Add-ArtifactContent -Key "requirements" -Label "requirements"
      $promptLines += "### Architecture Document"
      $promptLines += ""
      Add-ArtifactContent -Key "architecture" -Label "architecture"
      $promptLines += "### Team Plan Document"
      $promptLines += ""
      Add-ArtifactContent -Key "team_plan" -Label "team plan"
      $promptLines += "### Development Report"
      $promptLines += ""
      Add-ArtifactContent -Key "phase_dev" -Label "phase dev"
      $promptLines += "### Test Report"
      $promptLines += ""
      Add-ArtifactContent -Key "phase_test" -Label "phase test"
      $promptLines += "### Claude Lead Review"
      $promptLines += ""
      Add-ArtifactContent -Key "claude_lead_review" -Label "claude lead review"
      $promptLines += "### Phase Gate Files"
      $promptLines += ""
      foreach ($gateName in @("team_plan_gate.json", "phase_dev_gate.json", "phase_test_gate.json", "claude_lead_review_gate.json")) {
        $gateFile = ".agent\gates\$gateName"
        $promptLines += "#### $gateName"
        if (Test-Path $gateFile) {
          $promptLines += (Get-Content $gateFile -Raw -Encoding UTF8)
        } elseif ($gateName -eq "team_plan_gate.json") {
          # team_plan_gate is not present as standalone; team_plan is verified via other gates
          $teamPlanSource = if ($manifest.artifacts["team_plan"]) { $manifest.artifacts["team_plan"].source } else { "unknown" }
          $promptLines += "$($gateName): not present as standalone gate file"
          $promptLines += "team_plan artifact: verified via $teamPlanSource"
        } else {
          $promptLines += "($gateName not found)"
        }
        $promptLines += ""
      }
      $promptLines += "### Repository Guidelines (excerpts)"
      $promptLines += ""
      $promptLines += "This is a docs-only / pipeline-only smoke validation. No production trading code was modified."
      $promptLines += ""
      $promptLines += "### Output Format"
      $promptLines += ""
      $promptLines += "The Codex review report MUST contain these sections (in order):"
      $promptLines += ""
      $promptLines += "# $featureId Codex Review R1"
      $promptLines += "## Objective"
      $promptLines += "## Inputs Reviewed"
      $promptLines += "## Review Scope"
      $promptLines += "## Artifact Verification"
      $promptLines += "## Code Change Review"
      $promptLines += "## Workflow Review"
      $promptLines += "## Gate Review"
      $promptLines += "## Safety Review"
      $promptLines += "## Regression Risk"
      $promptLines += "## Findings"
      $promptLines += "## Required Fixes"
      $promptLines += "## Recommendations"
      $promptLines += "## Review Decision"
      $promptLines += "## Handoff to Acceptance"
      $promptLines += ""
      $promptLines += "### Important Notes"
      $promptLines += ""
      $promptLines += "- You are Codex B Reviewer — NOT a developer, tester, or PM."
      $promptLines += "- Current task is docs-only / pipeline smoke validation."
      $promptLines += "- Do NOT modify production code or trading-sensitive modules."
      $promptLines += "- Review Decision MUST be one of: APPROVED, APPROVED_WITH_NOTES, CHANGES_REQUESTED, BLOCKED."
      $promptLines += "- Do NOT infer artifact paths from date strings."
      $promptLines += "- Use the Resolved Artifact Manifest as the source of truth."
      $promptLines += "- Do NOT claim an artifact is missing if it is listed as exists=true in the manifest."
      $promptLines += "- If there is a conflict between guessed paths and gate found paths, trust gate found paths."
      $promptLines += "- For 'Safety Review', state: 'No production trading modules were modified. No broker / execution / order / account / risk / miniQMT / live trading code was changed. No real order submission behavior was introduced. Merge Gate and manual approval remain enforced.'"
      $promptLines += "- For 'Handoff to Acceptance', state: 'If AGENT_REAL_CODEX_ACCEPTANCE=true, Codex acceptance is real in V11 and must verify upstream artifacts, gates, state/gate consistency, and acceptance criteria using the Resolved Acceptance Manifest. If AGENT_REAL_CODEX_ACCEPTANCE_STRICT=true, real Codex failure must fail the acceptance stage without mock fallback. If acceptance is not enabled and strict is false, mock fallback is allowed only as explicit smoke fallback logged clearly. No auto-merge should occur. Manual approval remains required.'"
      $promptLines += "- The target output path is: $outPath"
      $promptLines += ""
      $promptLines += "REMINDER: Output ONLY the raw markdown. No conversation. No tool use. No file writing."
      $promptText = $promptLines -join "`r`n"

      # Write prompt to temp file (UTF-8 no BOM for WSL compat)
      $promptFile = [System.IO.Path]::GetTempFileName()
      $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
      [System.IO.File]::WriteAllText($promptFile, $promptText, $utf8NoBom)

      # Convert Windows path to WSL path: D:\... → /mnt/d/...
      $wslPath = "/mnt/" + $promptFile.Substring(0,1).ToLower() + $promptFile.Substring(2) -replace '\\', '/'

            # Derive WSL workspace path for --cd flag
      $wslWorkspace = "/mnt/" + $repo.Substring(0,1).ToLower() + $repo.Substring(2) -replace '\\', '/'

      Write-Host "Invoking real Codex via WSL..."

      # Write a small bash runner script to a temp file, then execute it via
      # wsl.exe -- bash /path. This avoids all quoting issues with bash -lc.
      $runnerFile = [System.IO.Path]::GetTempFileName()
      $wslOutputFile = "/tmp/codex_review_output_$([System.IO.Path]::GetRandomFileName()).md"
      $runnerScript = @"
set -e

export PATH="`$HOME/.nvm/versions/node/v22.16.0/bin:`$HOME/.local/bin:`$HOME/.opencode/bin:`$PATH"
# Proxy for OpenAI API connectivity (sourced from .bashrc, which is guarded
# by interactive-shell check and thus skipped in non-interactive wsl.exe
# invocations like -- bash runner.sh).
export HTTP_PROXY=http://127.0.0.1:7890
export HTTPS_PROXY=http://127.0.0.1:7890
export ALL_PROXY=socks5://127.0.0.1:7890
export NO_PROXY=localhost,127.0.0.1
if [ -n "${CODEX_CLI_PATH:-}" ] && [ -x "`$CODEX_CLI_PATH" ]; then
  CODEX_BIN="`$CODEX_CLI_PATH"
elif [ -x "/home/ly/.nvm/versions/node/v22.16.0/bin/codex" ]; then
  CODEX_BIN="/home/ly/.nvm/versions/node/v22.16.0/bin/codex"
else
  CODEX_BIN="`$(command -v codex || true)"
fi
if [ -z "`$CODEX_BIN" ]; then
  echo "ERROR: codex CLI not found in WSL PATH"
  echo "PATH=`$PATH"
  exit 127
fi
echo "Using Codex: `$CODEX_BIN"
"`$CODEX_BIN" --version
"`$CODEX_BIN" login status 2>&1 | head -3 || true

echo "Running Codex reviewer with 20m timeout..."

timeout --kill-after=30 1200 "`$CODEX_BIN" exec \
  --cd "$wslWorkspace" \
  --sandbox read-only \
  --color never \
  --output-last-message "$wslOutputFile" \
  - < "$wslPath"

CODEX_EXIT=`$?

if [ "`$CODEX_EXIT" -eq 124 ]; then
  echo "ERROR: Codex reviewer timed out after 20 minutes"
  exit 124
fi

if [ -s "$wslOutputFile" ]; then
  echo "OUTPUT_FILE: $wslOutputFile"
fi

exit "`$CODEX_EXIT"
"@
      $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
      [System.IO.File]::WriteAllText($runnerFile, $runnerScript, $utf8NoBom)

      $wslRunnerPath = "/mnt/" + $runnerFile.Substring(0,1).ToLower() + $runnerFile.Substring(2) -replace '\\', '/'

      # Use ProcessStartInfo to capture stdout/stderr separately.
      # Avoids $ErrorActionPreference=Stop treating stderr prompts
      # (like "Reading prompt from stdin...") as NativeCommandError.
      $psi = New-Object System.Diagnostics.ProcessStartInfo
      $psi.FileName = "wsl.exe"
      $psi.Arguments = "-- bash $wslRunnerPath"
      $psi.RedirectStandardOutput = $true
      $psi.RedirectStandardError = $true
      $psi.UseShellExecute = $false
      $psi.CreateNoWindow = $true

      $proc = New-Object System.Diagnostics.Process
      $proc.StartInfo = $psi

      # Use async event-based reads to avoid the pipe-buffer deadlock:
      # Codex echoes the full prompt back to stderr, which can exceed the
      # default 4 KB pipe buffer. Reading synchronously (ReadToEnd) would
      # deadlock when stderr fills up. Async reads drain both streams as
      # data arrives, keeping the pipes flowing.
      $stdoutBuilder = New-Object System.Text.StringBuilder
      $stderrBuilder = New-Object System.Text.StringBuilder
      $stdoutEvent = Register-ObjectEvent -InputObject $proc -EventName OutputDataReceived -Action { $stdoutBuilder.Append("$($EventArgs.Data)`n") }
      $stderrEvent = Register-ObjectEvent -InputObject $proc -EventName ErrorDataReceived -Action { $stderrBuilder.Append("$($EventArgs.Data)`n") }

      [void]$proc.Start()
      $proc.BeginOutputReadLine()
      $proc.BeginErrorReadLine()

      # Wait for exit with hard timeout (20 min + 30s grace), then SIGKILL
      $timeoutMs = 1200 * 1000 + 30000
      $exited = $proc.WaitForExit($timeoutMs)
      if (-not $exited) {
        Write-Host "WARNING: WSL process timed out after 20m30s, killing..."
        $proc.Kill()
        $proc.WaitForExit(10000)
      }

      # Unregister the async event handlers (suppress any errors)
      if ($stdoutEvent) { Unregister-Event -SourceIdentifier $stdoutEvent.Name -ErrorAction SilentlyContinue }
      if ($stderrEvent) { Unregister-Event -SourceIdentifier $stderrEvent.Name -ErrorAction SilentlyContinue }

      # Convert StringBuilder output to strings for downstream use
      $stdout = $stdoutBuilder.ToString()
      $stderr = $stderrBuilder.ToString()

      $rc = $proc.ExitCode

      Write-Host "Codex WSL exit code: $rc"

      # Print all output for CI log debugging
      if ($stdout) { Write-Host "STDOUT: $stdout" }
      if ($stderr) { Write-Host "STDERR: $stderr" }

      Remove-Item $promptFile -Force -ErrorAction SilentlyContinue
      Remove-Item $runnerFile -Force -ErrorAction SilentlyContinue

            # Try to read OUTPUT_FILE from WSL temp path
      $wslOutputWinPath = $wslOutputFile -replace '^/mnt/([a-z])/', '$1:\' -replace '/', '\'
      $gotRealOutput = $false
      if ((Test-Path $wslOutputWinPath) -and ((Get-Item $wslOutputWinPath).Length -gt 0)) {
        $reviewContent = Get-Content $wslOutputWinPath -Raw -Encoding UTF8
        if ($reviewContent -and $reviewContent.Trim().Length -gt 0) {
          $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
          [System.IO.File]::WriteAllText($outPath, $reviewContent.Trim(), $utf8NoBom)
          Write-Host "Generated $outPath using real Codex (via --output-last-message)"
          $gotRealOutput = $true
        }
        Remove-Item $wslOutputWinPath -Force -ErrorAction SilentlyContinue
      }

      if (-not $gotRealOutput) {
        if ($rc -eq 0 -and $stdout -and $stdout.Trim().Length -gt 0) {
          # Strip wrapper log lines from stdout before writing
          $cleanOutput = $stdout -replace '(?s)^.*?Using Codex:.*?codex-cli [\d.]+[\r\n]*', ''
          $cleanOutput = $cleanOutput -replace '(?s)Logged in.*?[\r\n]+', ''
          $cleanOutput = $cleanOutput -replace 'Reading prompt from stdin\.\.\.[\r\n]*', ''
          $cleanOutput = $cleanOutput -replace 'Running Codex reviewer.*?[\r\n]*', ''
          $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
          [System.IO.File]::WriteAllText($outPath, $cleanOutput.Trim(), $utf8NoBom)
          Write-Host "Generated $outPath using real Codex (stdout fallback)"
          $gotRealOutput = $true
        }
      }

      Remove-Item $promptFile -Force -ErrorAction SilentlyContinue
      Remove-Item $runnerFile -Force -ErrorAction SilentlyContinue

      if (-not $gotRealOutput) {
        $errorInfo = if ($rc -eq 124) { "Codex reviewer timed out after 20 minutes" } else { "$(if ($stdout) { $stdout } else { $stderr })" }
        if (-not $errorInfo) { $errorInfo = "(no output)" }
        Write-Host "WARNING: Real Codex mode failed (exit=$rc). $errorInfo" -ForegroundColor Yellow
        if ($useStrict) {
          Write-Error "AGENT_REAL_CODEX_REVIEWER_STRICT=true — real mode failed, aborting."
          exit 2
        }
        Write-Host "Falling back to mock mode." -ForegroundColor Yellow
      }
}

    # Mock/smoke fallback
    if (!(Test-Path $outPath) -or ((Get-Item $outPath).Length -eq 0)) {
      $lines = @(
        "# $featureId Codex Architecture Review R1",
        "",
        "> Smoke-test Codex B review generated by local Codex wrapper.",
        "> This file proves GitHub Actions can call the final Codex review stage command.",
        "",
        "## Stage",
        "",
        "codex_reviewer",
        "",
        "## Source Handoff",
        "",
        $handoff,
        "",
        "## Review Result",
        "",
        "APPROVED",
        "",
        "## Reviewed Evidence",
        "",
        "- Requirements document exists under ``docs/requirements/``.",
        "- Architecture document exists under ``docs/design/``.",
        "- Claude team plan exists under ``docs/dev_plans/``.",
        "- Claude phase development and test reports exist.",
        "- Claude lead review exists under ``docs/review/``.",
        "",
        "## Safety Notes",
        "",
        "No trading, risk, execution, broker, account, or live-trading module is modified by this smoke test.",
        "",
        "## Handoff Preview",
        "",
        "````text",
        $handoffPreview,
        "````"
      )
      Write-Utf8Markdown -Path $outPath -Lines $lines
    }
  }  "codex_acceptance" {
    $outPath = "docs\acceptance\$today-$featureId-acceptance.md"
    $guidePath = "docs\user_guides\$today-$featureId-user-guide.md"

    # Try real Codex mode when AGENT_REAL_CODEX_ACCEPTANCE=true or AGENT_REAL_CODEX_ACCEPTANCE_STRICT=true
    $useReal = $env:AGENT_REAL_CODEX_ACCEPTANCE -eq "true"
    $useStrict = $env:AGENT_REAL_CODEX_ACCEPTANCE_STRICT -eq "true"
    if ($useReal -or $useStrict) {
      # Sync state metadata from gates before acceptance, so the prompt
      # does not see stale stage_status / current_stage values.
      Write-Host "Syncing pipeline state from gates before acceptance..."
      python scripts/agent_pipeline.py sync-state-from-gates
      if ($LASTEXITCODE -eq 0) {
        Write-Host "State sync OK."
      } else {
        Write-Host "WARNING: sync-state-from-gates reported issues (non-fatal)."
      }
      python scripts/agent_pipeline.py check-state-gate-consistency
      # ----------------------------------------------------------------
      # Acceptance Artifact Manifest Resolver
      # Priority: gate JSON found fields > state.json required_docs > glob
      # Copied from codex_reviewer pattern with acceptance-specific keys.
      # ----------------------------------------------------------------
      $manifest = @{
        feature_id = $featureId
        artifacts  = @{}
        missing    = @()
      }

      $gateFiles = @{
        "requirements"       = @("acceptance_gate.json", "codex_review_gate.json", "claude_lead_review_gate.json")
        "architecture"       = @("acceptance_gate.json", "codex_review_gate.json", "claude_lead_review_gate.json")
        "team_plan"          = @("acceptance_gate.json", "codex_review_gate.json", "claude_lead_review_gate.json")
        "phase_dev"          = @("acceptance_gate.json", "codex_review_gate.json", "phase_test_gate.json")
        "phase_test"         = @("acceptance_gate.json", "codex_review_gate.json", "phase_test_gate.json")
        "claude_lead_review" = @("acceptance_gate.json", "codex_review_gate.json", "claude_lead_review_gate.json")
        "codex_review"       = @("acceptance_gate.json", "codex_review_gate.json")
      }
      $gateFoundKeys = @{
        "requirements"       = "pm"
        "architecture"       = "architecture"
        "team_plan"          = "team_plan"
        "phase_dev"          = "phase_dev"
        "phase_test"         = "phase_test"
        "claude_lead_review" = "claude_lead_review"
        "codex_review"       = "codex_review"
      }

      foreach ($key in $gateFiles.Keys) {
        $resolvedPath = $null
        $sourceDesc = ""
        $candidateGates = $gateFiles[$key]
        $foundKey = $gateFoundKeys[$key]

        # Priority 1: gate JSON found fields
        foreach ($gName in $candidateGates) {
          $gFile = ".agent\gates\$gName"
          if (Test-Path $gFile) {
            $gContent = Get-Content $gFile -Raw -Encoding UTF8 | ConvertFrom-Json
            if ($gContent.found -and $gContent.found.$foundKey) {
              $paths = $gContent.found.$foundKey
              if ($paths.Count -gt 0 -and $paths[0]) {
                $resolvedPath = $paths[0] -replace '\\', '/'
                $sourceDesc = ".agent\gates\$gName found.$foundKey"
                break
              }
            }
          }
        }

        # Priority 2: state.json required_docs
        if (-not $resolvedPath -and $state.required_docs) {
          $stateKey = $key
          if ($state.required_docs.$stateKey) {
            $resolvedPath = $state.required_docs.$stateKey -replace '\\', '/'
            $sourceDesc = ".agent/state.json required_docs.$stateKey"
          }
        }

        # Priority 3: glob fallback
        if (-not $resolvedPath) {
          $patterns = @()
          switch ($key) {
            "requirements"       { $patterns = @("*$featureId*requirements*", "*$featureId*pm*") }
            "architecture"       { $patterns = @("*$featureId*architecture*", "*$featureId*arch*") }
            "team_plan"          { $patterns = @("*$featureId*team-plan*", "*$featureId*team_plan*") }
            "phase_dev"          { $patterns = @("*$featureId*dev-report*", "*$featureId*phase-*-dev*") }
            "phase_test"         { $patterns = @("*$featureId*test-report*", "*$featureId*phase-*-test*") }
            "claude_lead_review" { $patterns = @("*$featureId*lead-review*", "*$featureId*claude-lead*") }
            "codex_review"       { $patterns = @("*$featureId*codex-review*", "*$featureId*codex*") }
          }
          $globDirs = @("docs\requirements", "docs\design", "docs\dev_plans", "docs\dev_reports", "docs\test_reports", "docs\review")
          foreach ($pat in $patterns) {
            foreach ($dir in $globDirs) {
              $matches = Get-ChildItem -Path "$dir\$pat" -ErrorAction SilentlyContinue
              if ($matches) {
                $resolvedPath = $matches[0].FullName -replace '\\', '/' -replace '^.*?(docs/)', '$1'
                $sourceDesc = "glob $dir\$pat"
                break
              }
            }
            if ($resolvedPath) { break }
          }
        }

        $exists = $false
        if ($resolvedPath) {
          $exists = Test-Path $resolvedPath
        }

        if ($resolvedPath) {
          $manifest.artifacts[$key] = @{ path = $resolvedPath; source = $sourceDesc; exists = $exists }
        } else {
          $manifest.missing += $key
        }
      }

      # Write acceptance manifest
      $manifestDir = ".agent"
      $manifestPath = Join-Path $manifestDir "artifact_manifest_codex_acceptance.json"
      New-Item -ItemType Directory -Force -Path $manifestDir | Out-Null
      $manifestJson = $manifest | ConvertTo-Json -Depth 5
      [System.IO.File]::WriteAllText([System.IO.Path]::GetFullPath($manifestPath), $manifestJson, [System.Text.UTF8Encoding]::new($false))
      Write-Host "Generated $manifestPath"

      # Build acceptance prompt
      $promptLines = @()

      $promptLines += "Generate an acceptance report in Markdown format. Output ONLY the raw Markdown content to stdout — do NOT write any file, do NOT use any tools, do NOT include conversational text, greetings, or meta-commentary."
      $promptLines += ""
      $promptLines += "## Context"
      $promptLines += ""
      $promptLines += "### Current Stage"
      $promptLines += "codex_acceptance — You are Codex A (PM Acceptance). You verify that all upstream artifacts, gates, and reports are present and consistent before giving final acceptance for this feature."
      $promptLines += ""
      $promptLines += "### Feature ID"
      $promptLines += $featureId
      $promptLines += ""
      $promptLines += "### Handoff Content"
      $promptLines += ""
      $promptLines += $handoffText
      $promptLines += ""
      $promptLines += "### Pipeline State"
      $promptLines += ""
      $promptLines += (Get-Content $statePath -Raw -Encoding UTF8)
      $promptLines += ""

      # Build Resolved Acceptance Manifest table
      $promptLines += "## Resolved Acceptance Manifest"
      $promptLines += ""
      $promptLines += "IMPORTANT: Do NOT infer artifact paths from date strings or patterns below."
      $promptLines += "Use this manifest as the source of truth. If an artifact is listed as exists=true,"
      $promptLines += "it exists at the path shown — do NOT claim it is missing."
      $promptLines += ""
      $promptLines += "| Artifact | Path | Source | Exists |"
      $promptLines += "|---|---|---|---|"
      foreach ($artKey in @("requirements", "architecture", "team_plan", "phase_dev", "phase_test", "claude_lead_review", "codex_review")) {
        $a = $manifest.artifacts[$artKey]
        if ($a) {
          $promptLines += "| $artKey | $($a.path) | $($a.source) | $($a.exists) |"
        } else {
          $promptLines += "| $artKey | (missing) | - | false |"
        }
      }
      $promptLines += ""

      # Gate evidence
      $promptLines += "## Gate Evidence"
      $promptLines += ""
      foreach ($gateName in @("phase_dev_gate.json", "phase_test_gate.json", "claude_lead_review_gate.json", "codex_review_gate.json")) {
        $gateFile = ".agent\gates\$gateName"
        $promptLines += "### $gateName"
        if (Test-Path $gateFile) {
          $promptLines += (Get-Content $gateFile -Raw -Encoding UTF8)
        } else {
          $promptLines += "($gateName not found)"
        }
        $promptLines += ""
      }

      # Include artifact content for key reports
      function Add-ArtifactContent {
        param([string]$Key, [string]$Label)
        $a = $manifest.artifacts[$Key]
        if ($a -and $a.exists -and (Test-Path $a.path)) {
          $promptLines += (Get-Content $a.path -Raw -Encoding UTF8)
        } else {
          $status = if ($a) { "exists=$($a.exists), path=$($a.path), source=$($a.source)" } else { "artifact key not in manifest" }
          $promptLines += "($Label file — $status)"
        }
        $promptLines += ""
      }
      $promptLines += "### Requirements Document"
      $promptLines += ""
      Add-ArtifactContent -Key "requirements" -Label "requirements"
      $promptLines += "### Architecture Document"
      $promptLines += ""
      Add-ArtifactContent -Key "architecture" -Label "architecture"
      $promptLines += "### Team Plan Document"
      $promptLines += ""
      Add-ArtifactContent -Key "team_plan" -Label "team plan"
      $promptLines += "### Development Report"
      $promptLines += ""
      Add-ArtifactContent -Key "phase_dev" -Label "phase dev"
      $promptLines += "### Test Report"
      $promptLines += ""
      Add-ArtifactContent -Key "phase_test" -Label "phase test"
      $promptLines += "### Claude Lead Review"
      $promptLines += ""
      Add-ArtifactContent -Key "claude_lead_review" -Label "claude lead review"
      $promptLines += "### Codex Review R1"
      $promptLines += ""
      Add-ArtifactContent -Key "codex_review" -Label "codex review r1"

      $promptLines += ""
      $promptLines += "### Output Format"
      $promptLines += ""
      $promptLines += "The acceptance report MUST contain these sections (in order):"
      $promptLines += ""
      $promptLines += "# $featureId PM Acceptance"
      $promptLines += "## Acceptance Scope"
      $promptLines += "## Artifacts Reviewed"
      $promptLines += "## Gate Review"
      $promptLines += "## Safety Review"
      $promptLines += "## Acceptance Findings"
      $promptLines += "## Acceptance Decision"
      $promptLines += "## Handoff"
      $promptLines += ""
      $promptLines += "### Important Notes"
      $promptLines += ""
      $promptLines += "- You are Codex A (PM Acceptance) — NOT a developer, architect, or reviewer."
      $promptLines += "- Do NOT modify production code or trading-sensitive modules."
      $promptLines += "- Do NOT infer artifact paths from date strings."
      $promptLines += "- Use the Resolved Acceptance Manifest as the source of truth."
      $promptLines += "- Do NOT claim an artifact is missing if it is listed as exists=true in the manifest."
      $promptLines += "- If state metadata conflicts with gate evidence, trust gate evidence."
      $promptLines += "- Acceptance Decision MUST be one of: ACCEPTED, ACCEPTED_WITH_NOTES, CHANGES_REQUESTED, BLOCKED."
      $promptLines += "- ACCEPTED_WITH_NOTES is ONLY acceptable for non-blocking notes."
      $promptLines += "- CHANGES_REQUESTED or BLOCKED must fail the acceptance gate."
      $promptLines += "- The target output path is: $outPath"
      $promptLines += ""
      $promptLines += "REMINDER: Output ONLY the raw markdown. No conversation. No tool use. No file writing."

      $promptText = $promptLines -join "`r`n"

      # Write prompt to temp file (UTF-8 no BOM for WSL compat)
      $promptFile = [System.IO.Path]::GetTempFileName()
      $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
      [System.IO.File]::WriteAllText($promptFile, $promptText, $utf8NoBom)

      # Convert Windows path to WSL path: D:\... \u2192 /mnt/d/...
      $wslPath = "/mnt/" + $promptFile.Substring(0,1).ToLower() + $promptFile.Substring(2) -replace '\\', '/'

      $wslWorkspace = "/mnt/" + $repo.Substring(0,1).ToLower() + $repo.Substring(2) -replace '\\', '/'

      Write-Host "Invoking real Codex for acceptance via WSL..."

      # Write bash runner script
      $runnerFile = [System.IO.Path]::GetTempFileName()
      $wslOutputFile = "/tmp/codex_accept_output_$([System.IO.Path]::GetRandomFileName()).md"
      $runnerScript = @"
set -e

export PATH="`$HOME/.nvm/versions/node/v22.16.0/bin:`$HOME/.local/bin:`$HOME/.opencode/bin:`$PATH"
export HTTP_PROXY=http://127.0.0.1:7890
export HTTPS_PROXY=http://127.0.0.1:7890
export ALL_PROXY=socks5://127.0.0.1:7890
export NO_PROXY=localhost,127.0.0.1
if [ -n "${CODEX_CLI_PATH:-}" ] && [ -x "`$CODEX_CLI_PATH" ]; then
  CODEX_BIN="`$CODEX_CLI_PATH"
elif [ -x "/home/ly/.nvm/versions/node/v22.16.0/bin/codex" ]; then
  CODEX_BIN="/home/ly/.nvm/versions/node/v22.16.0/bin/codex"
else
  CODEX_BIN="`$(command -v codex || true)"
fi
if [ -z "`$CODEX_BIN" ]; then
  echo "ERROR: codex CLI not found in WSL PATH"
  echo "PATH=`$PATH"
  exit 127
fi
echo "Using Codex: `$CODEX_BIN"
"`$CODEX_BIN" --version
"`$CODEX_BIN" login status 2>&1 | head -3 || true

echo "Running Codex acceptance with 20m timeout..."

timeout --kill-after=30 1200 "`$CODEX_BIN" exec   --cd "$wslWorkspace"   --sandbox read-only   --color never   --output-last-message "$wslOutputFile"   - < "$wslPath"

CODEX_EXIT=`$?

if [ "`$CODEX_EXIT" -eq 124 ]; then
  echo "ERROR: Codex acceptance timed out after 20 minutes"
  exit 124
fi

if [ -s "$wslOutputFile" ]; then
  echo "OUTPUT_FILE: $wslOutputFile"
fi

exit "`$CODEX_EXIT"
"@
      $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
      [System.IO.File]::WriteAllText($runnerFile, $runnerScript, $utf8NoBom)

      $wslRunnerPath = "/mnt/" + $runnerFile.Substring(0,1).ToLower() + $runnerFile.Substring(2) -replace '\\', '/'

      # Use ProcessStartInfo to capture stdout/stderr separately.
      $psi = New-Object System.Diagnostics.ProcessStartInfo
      $psi.FileName = "wsl.exe"
      $psi.Arguments = "-- bash $wslRunnerPath"
      $psi.RedirectStandardOutput = $true
      $psi.RedirectStandardError = $true
      $psi.UseShellExecute = $false
      $psi.CreateNoWindow = $true

      $proc = New-Object System.Diagnostics.Process
      $proc.StartInfo = $psi

      # Async reads to avoid pipe-buffer deadlock
      $stdoutBuilder = New-Object System.Text.StringBuilder
      $stderrBuilder = New-Object System.Text.StringBuilder
      $stdoutEvent = Register-ObjectEvent -InputObject $proc -EventName OutputDataReceived -Action { $stdoutBuilder.Append("$($EventArgs.Data)`n") }
      $stderrEvent = Register-ObjectEvent -InputObject $proc -EventName ErrorDataReceived -Action { $stderrBuilder.Append("$($EventArgs.Data)`n") }

      [void]$proc.Start()
      $proc.BeginOutputReadLine()
      $proc.BeginErrorReadLine()

      # Wait for exit with hard timeout (20 min + 30s grace), then SIGKILL
      $timeoutMs = 1200 * 1000 + 30000
      $exited = $proc.WaitForExit($timeoutMs)
      if (-not $exited) {
        Write-Host "WARNING: WSL process timed out after 20m30s, killing..."
        $proc.Kill()
        $proc.WaitForExit(10000)
      }

      # Unregister async event handlers
      if ($stdoutEvent) { Unregister-Event -SourceIdentifier $stdoutEvent.Name -ErrorAction SilentlyContinue }
      if ($stderrEvent) { Unregister-Event -SourceIdentifier $stderrEvent.Name -ErrorAction SilentlyContinue }

      $stdout = $stdoutBuilder.ToString()
      $stderr = $stderrBuilder.ToString()
      $rc = $proc.ExitCode

      Write-Host "Codex WSL exit code: $rc"
      if ($stdout) { Write-Host "STDOUT: $stdout" }
      if ($stderr) { Write-Host "STDERR: $stderr" }

      Remove-Item $promptFile -Force -ErrorAction SilentlyContinue
      Remove-Item $runnerFile -Force -ErrorAction SilentlyContinue

      # Try to read OUTPUT_FILE from WSL temp path
      $wslOutputWinPath = $wslOutputFile -replace '^/mnt/([a-z])/', '$1:\' -replace '/', '\'
      $gotRealOutput = $false
      if ((Test-Path $wslOutputWinPath) -and ((Get-Item $wslOutputWinPath).Length -gt 0)) {
        $acceptContent = Get-Content $wslOutputWinPath -Raw -Encoding UTF8
        if ($acceptContent -and $acceptContent.Trim().Length -gt 0) {
          $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
          [System.IO.File]::WriteAllText($outPath, $acceptContent.Trim(), $utf8NoBom)
          Write-Host "Generated $outPath using real Codex (via --output-last-message)"
          $gotRealOutput = $true
        }
        Remove-Item $wslOutputWinPath -Force -ErrorAction SilentlyContinue
      }

      if (-not $gotRealOutput) {
        if ($rc -eq 0 -and $stdout -and $stdout.Trim().Length -gt 0) {
          $cleanOutput = $stdout -replace '(?s)^.*?Using Codex:.*?codex-cli [\d.]+[\r\n]*', ''
          $cleanOutput = $cleanOutput -replace '(?s)Logged in.*?[\r\n]+', ''
          $cleanOutput = $cleanOutput -replace 'Reading prompt from stdin\.\.\.[\r\n]*', ''
          $cleanOutput = $cleanOutput -replace 'Running Codex acceptance.*?[\r\n]*', ''
          $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
          [System.IO.File]::WriteAllText($outPath, $cleanOutput.Trim(), $utf8NoBom)
          Write-Host "Generated $outPath using real Codex (stdout fallback)"
          $gotRealOutput = $true
        }
      }

      Remove-Item $promptFile -Force -ErrorAction SilentlyContinue
      Remove-Item $runnerFile -Force -ErrorAction SilentlyContinue

      # Determine acceptance decision from output or exit code
      $decision = ""
      if ($gotRealOutput -and (Test-Path $outPath)) {
        $outText = Get-Content $outPath -Raw -Encoding UTF8
        if ($outText -match "\b(ACCEPTED|ACCEPTED_WITH_NOTES|CHANGES_REQUESTED|BLOCKED)\b") {
          $decision = $matches[1]
        }
      }

      # Generate acceptance gate
      $acceptedDecisions = @("ACCEPTED", "ACCEPTED_WITH_NOTES")
      $gatePassed = $gotRealOutput -and ($acceptedDecisions -contains $decision)
      $gateReasons = @()
      if ($gatePassed) {
        $gateReasons += "acceptance_decision_$decision"
      } else {
        $gateReasons += "acceptance_not_passed"
        if (-not $gotRealOutput) { $gateReasons += "no_real_output" }
      }

      $gatePayload = @{
        passed = $gatePassed
        feature_id = $featureId
        decision = if ($decision) { $decision } else { "UNKNOWN" }
        acceptance_artifact = "$outPath"
        reviewed_gates = @("phase_dev_gate.json", "phase_test_gate.json", "claude_lead_review_gate.json", "codex_review_gate.json")
        reviewed_artifacts = @($manifest.artifacts.Keys | ForEach-Object { $_.path })
        found = @{}
        missing = @{}
        reasons = $gateReasons
      }
      # Populate found from manifest
      foreach ($artKey in $manifest.artifacts.Keys) {
        $a = $manifest.artifacts[$artKey]
        if ($a.exists) {
          $gatePayload.found[$artKey] = @($a.path)
        } else {
          $gatePayload.missing[$artKey] = @($a.source)
        }
      }
      # Ensure acceptance itself is in found
      if ($gotRealOutput -and (Test-Path $outPath)) {
        if (-not $gatePayload.found["acceptance"]) {
          $gatePayload.found["acceptance"] = @("$outPath")
        }
      }

      $gatePath = ".agent\gates\acceptance_gate.json"
      $gateOutputDir = Split-Path -Parent $gatePath
      if ($gateOutputDir) {
        New-Item -ItemType Directory -Force -Path $gateOutputDir | Out-Null
      }
      $gateJson = $gatePayload | ConvertTo-Json -Depth 5
      $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
      [System.IO.File]::WriteAllText([System.IO.Path]::GetFullPath((Join-Path $repo $gatePath)), $gateJson, $utf8NoBom)
      Write-Host "Generated $gatePath"

      if (-not $gotRealOutput) {
        $errorInfo = if ($rc -eq 124) { "Codex acceptance timed out after 20 minutes" } else { "$(if ($stdout) { $stdout } else { $stderr })" }
        if (-not $errorInfo) { $errorInfo = "(no output)" }
        Write-Host "WARNING: Real Codex acceptance mode failed (exit=$rc). $errorInfo" -ForegroundColor Yellow
        if ($useStrict) {
          Write-Error "AGENT_REAL_CODEX_ACCEPTANCE_STRICT=true — real acceptance mode failed, aborting."
          exit 2
        }
        Write-Host "Falling back to mock acceptance mode." -ForegroundColor Yellow
      }
    }

    # Mock/smoke fallback
    if (!(Test-Path $outPath) -or ((Get-Item $outPath).Length -eq 0)) {
      $lines = @(
        "# $featureId PM Acceptance",
        "",
        "> Smoke-test PM acceptance generated by local Codex wrapper.",
        "> This file proves GitHub Actions can call the final Codex acceptance stage command.",
        "",
        "## Stage",
        "",
        "codex_acceptance",
        "",
        "## Source Handoff",
        "",
        $handoff,
        "",
        "## Acceptance Result",
        "",
        "PASS",
        "",
        "## Acceptance Checks",
        "",
        "| Check | Result |",
        "|---|---|",
        "| Requirements generated | PASS |",
        "| Architecture generated | PASS |",
        "| Claude team plan generated | PASS |",
        "| Claude developer report generated | PASS |",
        "| Claude tester report generated | PASS |",
        "| Claude lead review generated | PASS |",
        "| Codex review generated | PASS |",
        "",
        "## Safety Notes",
        "",
        "This smoke test is docs-only and does not affect real trading capability.",
        "",
        "## Handoff Preview",
        "",
        "\`\`\`\`text",
        $handoffPreview,
        "\`\`\`\`"
      )
      Write-Utf8Markdown -Path $outPath -Lines $lines
    }

    $guideLines = @(
      "# $featureId User Guide",
      "",
      "This smoke-test guide confirms that the issue-driven Agent pipeline reached PM acceptance.",
      "",
      "## Verification",
      "",
      "- The PR should contain requirements, architecture, team plan, development report, test report, lead review, Codex review, and PM acceptance artifacts.",
      "- The next stage should be \`\`stage:merge-ready\`\` followed by the main merge gate.",
      "",
      "## Safety",
      "",
      "This test does not perform real trading or call production broker APIs."
    )
    Write-Utf8Markdown -Path $guidePath -Lines $guideLines
  }  }
  default {
    Write-Error "Unsupported smoke-test stage: $Stage"
    exit 2
  }
}


