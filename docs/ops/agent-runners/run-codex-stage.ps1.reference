param(
  [Parameter(Mandatory=$true)]
  [string]$Stage
)

$ErrorActionPreference = "Stop"

$repoCandidates = @(
  $env:GITHUB_WORKSPACE,
  "D:\actions-runner\_work\quant-trading-agent\quant-trading-agent",
  "D:\Repo\quant-trading-agent",
  (Get-Location).Path
) | Where-Object { $_ -and (Test-Path $_) }

if (-not $repoCandidates -or $repoCandidates.Count -eq 0) {
  Write-Error "Cannot locate repository workspace. GITHUB_WORKSPACE='$env:GITHUB_WORKSPACE'"
  exit 2
}

$repo = $repoCandidates[0]
Set-Location $repo
Write-Host "Using repository workspace: $repo"

$handoff = Join-Path ".agent\handoff" "$Stage.md"
if (!(Test-Path $handoff)) {
  Write-Error "Missing handoff: $handoff"
  exit 2
}

$statePath = ".agent\state.json"
if (!(Test-Path $statePath)) {
  Write-Error "Missing pipeline state: $statePath"
  exit 2
}

$state = Get-Content $statePath -Raw -Encoding UTF8 | ConvertFrom-Json
$featureId = $state.feature_id
if (-not $featureId) {
  Write-Error "Missing feature_id in .agent/state.json"
  exit 2
}

$today = Get-Date -Format "yyyy-MM-dd"
$handoffText = Get-Content $handoff -Raw -Encoding UTF8
$previewLength = [Math]::Min(1200, $handoffText.Length)
$handoffPreview = $handoffText.Substring(0, $previewLength)

function Write-Utf8Markdown {
  param(
    [Parameter(Mandatory=$true)]
    [string]$Path,
    [Parameter(Mandatory=$true)]
    [object[]]$Lines
  )
  $parent = Split-Path -Parent $Path
  if ($parent) {
    New-Item -ItemType Directory -Force -Path $parent | Out-Null
  }
  Set-Content -Path $Path -Value ($Lines -join [Environment]::NewLine) -Encoding UTF8
  Write-Host "Generated $Path"
}

switch ($Stage) {
  "codex_pm" {
    $outPath = "docs\requirements\$today-$featureId-requirements.md"
    $lines = @(
      "# $featureId Requirements",
      "",
      "> Smoke-test document generated by local Codex wrapper.",
      "> This file proves GitHub Actions can call the local Windows Codex PM stage command.",
      "",
      "## Stage",
      "",
      "codex_pm",
      "",
      "## Source Handoff",
      "",
      $handoff,
      "",
      "## User Goal",
      "",
      "This is a temporary smoke-test requirements document. Replace this wrapper with the real Codex command after the command chain is verified.",
      "",
      "## Functional Requirements",
      "",
      "| ID | Requirement | Acceptance Criteria | Priority |",
      "|---|---|---|---|",
      "| F-001 | Verify local Codex PM command execution | Workflow calls the local wrapper and writes this requirements file | MUST |",
      "",
      "## Acceptance Criteria",
      "",
      "- The workflow can call ``C:\agent-runners\run-codex-stage.ps1``.",
      "- The script can read ``.agent/state.json``.",
      "- The script can read ``.agent/handoff/codex_pm.md``.",
      "- The script can write a requirements document under ``docs/requirements/``.",
      "",
      "## Handoff Preview",
      "",
      "````text",
      $handoffPreview,
      "````"
    )
    Write-Utf8Markdown -Path $outPath -Lines $lines
  }
  "codex_architect" {
    $requirementsPath = "docs\requirements\$today-$featureId-requirements.md"
    $outPath = "docs\design\$today-$featureId-architecture.md"
    $requirementsStatus = if (Test-Path $requirementsPath) { "found: $requirementsPath" } else { "not found at expected path: $requirementsPath" }
    $lines = @(
      "# $featureId Architecture",
      "",
      "> Smoke-test architecture document generated by local Codex wrapper.",
      "> This file proves GitHub Actions can call the local Windows Codex Architect stage command.",
      "",
      "## Stage",
      "",
      "codex_architect",
      "",
      "## Source Handoff",
      "",
      $handoff,
      "",
      "## Upstream Requirements",
      "",
      $requirementsStatus,
      "",
      "## Architecture Summary",
      "",
      "This smoke-test architecture keeps the implementation intentionally minimal. It does not change trading, risk, execution, broker, account, strategy, data-provider, or live-trading modules.",
      "",
      "## Module Plan",
      "",
      "| Module | Responsibility |",
      "|---|---|",
      "| ``.agent/`` | Pipeline state and handoff files |",
      "| ``docs/requirements/`` | Codex A PM output |",
      "| ``docs/design/`` | Codex B architecture output |",
      "",
      "## Development Guidance for Claude Team",
      "",
      "- Claude Code A may create a team plan from this smoke-test architecture.",
      "- Claude Code B/C should not modify production trading code for this smoke test.",
      "- Any later real feature must replace this smoke-test document with real architecture content.",
      "",
      "## Safety Impact",
      "",
      "No real trading capability is affected. No risk, execution, broker, account, or order logic is touched.",
      "",
      "## Handoff Preview",
      "",
      "````text",
      $handoffPreview,
      "````"
    )
    Write-Utf8Markdown -Path $outPath -Lines $lines
  }
  "codex_reviewer" {
    $outPath = "docs\review\$today-$featureId-codex-review-r1.md"

    # Try real Codex mode when AGENT_REAL_CODEX_REVIEWER=true or AGENT_REAL_CODEX_REVIEWER_STRICT=true
    $useReal = $env:AGENT_REAL_CODEX_REVIEWER -eq "true"
    $useStrict = $env:AGENT_REAL_CODEX_REVIEWER_STRICT -eq "true"
    if ($useReal -or $useStrict) {
      # Derive upstream artifact paths from state
      $reqPath = $state.required_docs.requirements
      $archPath = $state.required_docs.architecture
      $teamPlanPath = $state.required_docs.team_plan
      $devPat = $state.required_docs.phase_dev_report_pattern
      $testPat = $state.required_docs.phase_test_report_pattern
      $phaseNum = if ($state.team_pipeline) { $state.team_pipeline.current_phase } else { 1 }
      $devReportPath = if ($devPat) { $devPat -replace '<n>', $phaseNum } else { "" }
      $testReportPath = if ($testPat) { $testPat -replace '<n>', $phaseNum } else { "" }
      $leadReviewPath = "docs\review\$today-$featureId-claude-lead-review.md"

      # Build prompt parts
      $promptLines = @()

      $promptLines += "Generate a Codex review report (R1) in Markdown format. Output ONLY the raw Markdown content to stdout — do NOT write any file, do NOT use any tools, do NOT include conversational text, greetings, or meta-commentary."
      $promptLines += ""
      $promptLines += "## Context"
      $promptLines += ""
      $promptLines += "### Current Stage"
      $promptLines += "codex_reviewer — You are Codex B (Architect Reviewer). You are NOT a developer, tester, or PM. You perform independent code/process/safety review."
      $promptLines += ""
      $promptLines += "### Feature ID"
      $promptLines += $featureId
      $promptLines += ""
      $promptLines += "### Handoff Content (from claude_lead_review stage)"
      $promptLines += ""
      $promptLines += $handoffText
      $promptLines += ""
      $promptLines += "### Pipeline State"
      $promptLines += ""
      $promptLines += (Get-Content $statePath -Raw -Encoding UTF8)
      $promptLines += ""
      $promptLines += "### Requirements Document"
      $promptLines += ""
      if ($reqPath -and (Test-Path $reqPath)) {
        $promptLines += (Get-Content $reqPath -Raw -Encoding UTF8)
      } else { $promptLines += "(requirements file not found at: $reqPath)" }
      $promptLines += ""
      $promptLines += "### Architecture Document"
      $promptLines += ""
      if ($archPath -and (Test-Path $archPath)) {
        $promptLines += (Get-Content $archPath -Raw -Encoding UTF8)
      } else { $promptLines += "(architecture file not found at: $archPath)" }
      $promptLines += ""
      $promptLines += "### Team Plan Document"
      $promptLines += ""
      if ($teamPlanPath -and (Test-Path $teamPlanPath)) {
        $promptLines += (Get-Content $teamPlanPath -Raw -Encoding UTF8)
      } else { $promptLines += "(team plan file not found at: $teamPlanPath)" }
      $promptLines += ""
      $promptLines += "### Development Report"
      $promptLines += ""
      if ($devReportPath -and (Test-Path $devReportPath)) {
        $promptLines += (Get-Content $devReportPath -Raw -Encoding UTF8)
      } else { $promptLines += "(dev report file not found at: $devReportPath)" }
      $promptLines += ""
      $promptLines += "### Test Report"
      $promptLines += ""
      if ($testReportPath -and (Test-Path $testReportPath)) {
        $promptLines += (Get-Content $testReportPath -Raw -Encoding UTF8)
      } else { $promptLines += "(test report file not found at: $testReportPath)" }
      $promptLines += ""
      $promptLines += "### Claude Lead Review"
      $promptLines += ""
      if (Test-Path $leadReviewPath) {
        $promptLines += (Get-Content $leadReviewPath -Raw -Encoding UTF8)
      } else { $promptLines += "(lead review file not found at: $leadReviewPath)" }
      $promptLines += ""
      $promptLines += "### Phase Gate Files"
      $promptLines += ""
      foreach ($gateName in @("team_plan_gate.json", "phase_dev_gate.json", "phase_test_gate.json", "claude_lead_review_gate.json")) {
        $gateFile = ".agent\gates\$gateName"
        $promptLines += "#### $gateName"
        if (Test-Path $gateFile) {
          $promptLines += (Get-Content $gateFile -Raw -Encoding UTF8)
        } else { $promptLines += "($gateName not found)" }
        $promptLines += ""
      }
      $promptLines += "### Repository Guidelines (excerpts)"
      $promptLines += ""
      $promptLines += "This is a docs-only / pipeline-only smoke validation. No production trading code was modified."
      $promptLines += ""
      $promptLines += "### Output Format"
      $promptLines += ""
      $promptLines += "The Codex review report MUST contain these sections (in order):"
      $promptLines += ""
      $promptLines += "# $featureId Codex Review R1"
      $promptLines += "## Objective"
      $promptLines += "## Inputs Reviewed"
      $promptLines += "## Review Scope"
      $promptLines += "## Artifact Verification"
      $promptLines += "## Code Change Review"
      $promptLines += "## Workflow Review"
      $promptLines += "## Gate Review"
      $promptLines += "## Safety Review"
      $promptLines += "## Regression Risk"
      $promptLines += "## Findings"
      $promptLines += "## Required Fixes"
      $promptLines += "## Recommendations"
      $promptLines += "## Review Decision"
      $promptLines += "## Handoff to Acceptance"
      $promptLines += ""
      $promptLines += "### Important Notes"
      $promptLines += ""
      $promptLines += "- You are Codex B Reviewer — NOT a developer, tester, or PM."
      $promptLines += "- Current task is docs-only / pipeline smoke validation."
      $promptLines += "- Do NOT modify production code or trading-sensitive modules."
      $promptLines += "- Review Decision MUST be one of: APPROVED, APPROVED_WITH_NOTES, CHANGES_REQUESTED, BLOCKED."
      $promptLines += "- For 'Safety Review', state: 'No production trading modules were modified. No broker / execution / order / account / risk / miniQMT / live trading code was changed. No real order submission behavior was introduced. Merge Gate and manual approval remain enforced.'"
      $promptLines += "- For 'Handoff to Acceptance', state: 'Codex acceptance remains mock in V10. Acceptance should verify required artifacts and gates only. No auto-merge should occur. Manual approval remains required.'"
      $promptLines += "- The target output path is: $outPath"
      $promptLines += ""
      $promptLines += "REMINDER: Output ONLY the raw markdown. No conversation. No tool use. No file writing."

      $promptText = $promptLines -join "`r`n"

      # Write prompt to temp file (UTF-8 no BOM for WSL compat)
      $promptFile = [System.IO.Path]::GetTempFileName()
      $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
      [System.IO.File]::WriteAllText($promptFile, $promptText, $utf8NoBom)

      # Convert Windows path to WSL path: D:\... → /mnt/d/...
      $wslPath = "/mnt/" + $promptFile.Substring(0,1).ToLower() + $promptFile.Substring(2) -replace '\\', '/'

      Write-Host "Invoking real Codex via WSL..."

      # Write a small bash runner script to a temp file, then execute it via
      # wsl.exe -- bash /path. This avoids all quoting issues with bash -lc.
      $runnerFile = [System.IO.Path]::GetTempFileName()
      $runnerScript = @"
export PATH="`$HOME/.nvm/versions/node/v22.16.0/bin:`$HOME/.local/bin:`$HOME/.opencode/bin:`$PATH"
if [ -n "${CODEX_CLI_PATH:-}" ] && [ -x "`$CODEX_CLI_PATH" ]; then
  CODEX_BIN="`$CODEX_CLI_PATH"
elif [ -x "/home/ly/.nvm/versions/node/v22.16.0/bin/codex" ]; then
  CODEX_BIN="/home/ly/.nvm/versions/node/v22.16.0/bin/codex"
else
  CODEX_BIN="`$(command -v codex || true)"
fi
if [ -z "`$CODEX_BIN" ]; then
  echo "ERROR: codex CLI not found in WSL PATH"
  echo "PATH=`$PATH"
  exit 127
fi
echo "Using Codex: `$CODEX_BIN"
`$CODEX_BIN --version
exec "`$CODEX_BIN" exec < "$wslPath"
"@
      $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
      [System.IO.File]::WriteAllText($runnerFile, $runnerScript, $utf8NoBom)

      $wslRunnerPath = "/mnt/" + $runnerFile.Substring(0,1).ToLower() + $runnerFile.Substring(2) -replace '\\', '/'

      $output = & wsl.exe -- bash $wslRunnerPath 2>&1
      $rc = $LASTEXITCODE

      Write-Host "Codex WSL exit code: $rc"

      Remove-Item $promptFile -Force -ErrorAction SilentlyContinue
      Remove-Item $runnerFile -Force -ErrorAction SilentlyContinue

      if ($rc -eq 0 -and $output -and $output.Trim().Length -gt 0) {
        # Strip the "Using Codex: ..." and "codex-cli ..." lines from output,
        # keeping only the actual exec response.
        $cleanOutput = $output -replace '(?s)^.*?Using Codex:.*?codex-cli [\d.]+[\r\n]*', ''
        $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
        [System.IO.File]::WriteAllText($outPath, $cleanOutput.Trim(), $utf8NoBom)
        Write-Host "Generated $outPath using real Codex"
      } else {
        Write-Host "WARNING: Real Codex mode failed (exit=$rc)." -ForegroundColor Yellow
        if ($output) {
          $output | ForEach-Object { Write-Host "  $_" }
        }
        if ($useStrict) {
          Write-Error "AGENT_REAL_CODEX_REVIEWER_STRICT=true — real mode failed, aborting."
          exit 2
        }
        Write-Host "Falling back to mock mode." -ForegroundColor Yellow
      }
    }

    # Mock/smoke fallback
    if (!(Test-Path $outPath) -or ((Get-Item $outPath).Length -eq 0)) {
      $lines = @(
        "# $featureId Codex Architecture Review R1",
        "",
        "> Smoke-test Codex B review generated by local Codex wrapper.",
        "> This file proves GitHub Actions can call the final Codex review stage command.",
        "",
        "## Stage",
        "",
        "codex_reviewer",
        "",
        "## Source Handoff",
        "",
        $handoff,
        "",
        "## Review Result",
        "",
        "APPROVED",
        "",
        "## Reviewed Evidence",
        "",
        "- Requirements document exists under ``docs/requirements/``.",
        "- Architecture document exists under ``docs/design/``.",
        "- Claude team plan exists under ``docs/dev_plans/``.",
        "- Claude phase development and test reports exist.",
        "- Claude lead review exists under ``docs/review/``.",
        "",
        "## Safety Notes",
        "",
        "No trading, risk, execution, broker, account, or live-trading module is modified by this smoke test.",
        "",
        "## Handoff Preview",
        "",
        "````text",
        $handoffPreview,
        "````"
      )
      Write-Utf8Markdown -Path $outPath -Lines $lines
    }
  }
  "codex_acceptance" {
    $outPath = "docs\acceptance\$today-$featureId-acceptance.md"
    $guidePath = "docs\user_guides\$today-$featureId-user-guide.md"
    $lines = @(
      "# $featureId PM Acceptance",
      "",
      "> Smoke-test PM acceptance generated by local Codex wrapper.",
      "> This file proves GitHub Actions can call the final Codex acceptance stage command.",
      "",
      "## Stage",
      "",
      "codex_acceptance",
      "",
      "## Source Handoff",
      "",
      $handoff,
      "",
      "## Acceptance Result",
      "",
      "PASS",
      "",
      "## Acceptance Checks",
      "",
      "| Check | Result |",
      "|---|---|",
      "| Requirements generated | PASS |",
      "| Architecture generated | PASS |",
      "| Claude team plan generated | PASS |",
      "| Claude developer report generated | PASS |",
      "| Claude tester report generated | PASS |",
      "| Claude lead review generated | PASS |",
      "| Codex review generated | PASS |",
      "",
      "## Safety Notes",
      "",
      "This smoke test is docs-only and does not affect real trading capability.",
      "",
      "## Handoff Preview",
      "",
      "````text",
      $handoffPreview,
      "````"
    )
    Write-Utf8Markdown -Path $outPath -Lines $lines

    $guideLines = @(
      "# $featureId User Guide",
      "",
      "This smoke-test guide confirms that the issue-driven Agent pipeline reached PM acceptance.",
      "",
      "## Verification",
      "",
      "- The PR should contain requirements, architecture, team plan, development report, test report, lead review, Codex review, and PM acceptance artifacts.",
      "- The next stage should be ``stage:merge-ready`` followed by the main merge gate.",
      "",
      "## Safety",
      "",
      "This test does not perform real trading or call production broker APIs."
    )
    Write-Utf8Markdown -Path $guidePath -Lines $guideLines
  }
  default {
    Write-Error "Unsupported smoke-test stage: $Stage"
    exit 2
  }
}


