# Team Pipeline V2 local command examples.
# Copy values into GitHub repository Variables/Secrets or into a self-hosted
# runner environment. Do not store real tokens in this file.

# Codex A: Product Manager requirements.
CODEX_A_PM_AGENT_COMMAND=powershell -NoProfile -ExecutionPolicy Bypass -File C:\agent-runners\run-codex-stage.ps1 -Stage codex_pm

# Codex B: Architect design.
CODEX_B_ARCHITECT_AGENT_COMMAND=powershell -NoProfile -ExecutionPolicy Bypass -File C:\agent-runners\run-codex-stage.ps1 -Stage codex_architect

# Claude Code A: team plan, lead review, postmortem.
# If Claude Code is routed through ccswitch -> opencode-go -> DeepSeek, keep
# that logic inside scripts/run_claude_stage.sh. The workflow only needs one
# stable command per stage.
CLAUDE_LEAD_AGENT_COMMAND=wsl.exe -d Ubuntu -- bash -lc 'cd /mnt/d/repo/work/signalGPTV2/quant-trading-agent && ./scripts/run_claude_stage.sh "$STAGE"'

# Claude Code B: phase development.
CLAUDE_DEVELOPER_AGENT_COMMAND=wsl.exe -d Ubuntu -- bash -lc 'cd /mnt/d/repo/work/signalGPTV2/quant-trading-agent && ./scripts/run_claude_stage.sh claude_developer'

# Claude Code C: phase testing.
CLAUDE_TESTER_AGENT_COMMAND=wsl.exe -d Ubuntu -- bash -lc 'cd /mnt/d/repo/work/signalGPTV2/quant-trading-agent && ./scripts/run_claude_stage.sh claude_tester'

# Bugfix loop.
BUGFIX_AGENT_COMMAND=wsl.exe -d Ubuntu -- bash -lc 'cd /mnt/d/repo/work/signalGPTV2/quant-trading-agent && ./scripts/run_claude_stage.sh bugfix'

# Codex B: final architecture review.
CODEX_B_REVIEW_AGENT_COMMAND=powershell -NoProfile -ExecutionPolicy Bypass -File C:\agent-runners\run-codex-stage.ps1 -Stage codex_reviewer

# Codex A: PM acceptance.
CODEX_A_ACCEPTANCE_AGENT_COMMAND=powershell -NoProfile -ExecutionPolicy Bypass -File C:\agent-runners\run-codex-stage.ps1 -Stage codex_acceptance
