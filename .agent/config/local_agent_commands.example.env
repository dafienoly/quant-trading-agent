# Team Pipeline V2 local command examples.
# Copy values into GitHub repository Variables/Secrets or into a self-hosted
# runner environment. Do not store real tokens in this file.

# Codex A: Product Manager requirements.
CODEX_A_PM_AGENT_COMMAND=powershell -NoProfile -ExecutionPolicy Bypass -File C:\agent-runners\run-codex-stage.ps1 -Stage codex_pm

# Codex B: Architect design.
CODEX_B_ARCHITECT_AGENT_COMMAND=powershell -NoProfile -ExecutionPolicy Bypass -File C:\agent-runners\run-codex-stage.ps1 -Stage codex_architect

# Team stages no longer use repository Variables/Secrets to select an Agent.
# GitHub workflows call scripts/run-team-stage.ps1, which dispatches to the
# repository-owned WSL runner with fixed models and effort:
# - Lead: OpenCode opencode-go/glm-5.2
# - Developer/BugFix: Claude Code ultracode-xhigh, effort=xhigh
# - Tester: OpenCode opencode-go/deepseek-v4-pro, variant=max
# All three routes require superpowers; Developer also requires feature-dev.
#
# Optional: set the WSL distribution name on the self-hosted runner.
AGENT_WSL_DISTRO=Ubuntu

# Codex B: final architecture review.
CODEX_B_REVIEW_AGENT_COMMAND=powershell -NoProfile -ExecutionPolicy Bypass -File C:\agent-runners\run-codex-stage.ps1 -Stage codex_reviewer

# Codex A: PM acceptance.
CODEX_A_ACCEPTANCE_AGENT_COMMAND=powershell -NoProfile -ExecutionPolicy Bypass -File C:\agent-runners\run-codex-stage.ps1 -Stage codex_acceptance
