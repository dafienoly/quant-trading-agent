# 量化交易系统环境变量配置
# 复制本文件为 .env 并填入真实值
# cp .env.example .env

# ============================================================
# 交易模式配置
# ============================================================
# LEVEL_0: 研究模式（只读数据+报告）
# LEVEL_1_SIGNAL_ONLY: 信号模式（生成买卖建议，默认）
# LEVEL_2_HUMAN_CONFIRM: 人工确认模式
# LEVEL_3_AUTO: 自动交易模式（需严格条件）
MAX_TRADING_LEVEL=LEVEL_1_SIGNAL_ONLY
ENABLE_LIVE_TRADING=false
REQUIRE_HUMAN_CONFIRMATION=true

# ============================================================
# 数据源配置
# ============================================================
# AkShare（免费，无需 key）
# Tushare（需要 token）
TUSHARE_TOKEN=
# 其他数据源按需配置
EASTMONEY_ENABLED=true
SINA_QUOTE_ENABLED=true

# ============================================================
# 数据库配置
# ============================================================
# 初期使用 SQLite/DuckDB
DATABASE_URL=sqlite:///data/quant_trading.db
# 中期可切换 PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/quant_trading

# ============================================================
# 风控参数
# ============================================================
MAX_SINGLE_STOCK_POSITION=0.15
MAX_SECTOR_POSITION=0.60
MIN_CASH_RATIO=0.20
SINGLE_STOCK_LOSS_WARN=-0.05
SINGLE_STOCK_LOSS_STOP=-0.08
DAILY_LOSS_WARN=-0.02
DAILY_LOSS_STOP=-0.03
MAX_DRAWDOWN_DEFENSE=-0.08
MAX_DRAWDOWN_HALT=-0.12

# ============================================================
# 回测参数
# ============================================================
BACKTEST_COMMISSION_RATE=0.0003
BACKTEST_STAMP_DUTY=0.001
BACKTEST_SLIPPAGE=0.001

# ============================================================
# 券商接口配置（LEVEL_2+ 使用）
# ============================================================
BROKER_ADAPTER=paper
# BROKER_API_KEY=
# BROKER_API_SECRET=
# BROKER_ACCOUNT=

# ============================================================
# 日志配置
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/quant_trading.log

# ============================================================
# 通知配置（可选）
# ============================================================
# NOTIFY_EMAIL=
# NOTIFY_WEBHOOK_URL=

# ============================================================
# DeepSeek API (BugFix Agent)
# ============================================================
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
