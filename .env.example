# 量化交易系统环境变量配置
# 复制本文件为 .env 并填入真实值
# cp .env.example .env

# ============================================================
# 交易模式配置
# ============================================================
# LEVEL_0: 研究模式（只读数据+报告）
# LEVEL_1_SIGNAL_ONLY: 信号模式（生成买卖建议，默认）
# LEVEL_2_HUMAN_CONFIRM: 人工确认模式
# LEVEL_3_AUTO: 自动交易模式（需严格条件）
MAX_TRADING_LEVEL=LEVEL_1_SIGNAL_ONLY
ENABLE_LIVE_TRADING=false
REQUIRE_HUMAN_CONFIRMATION=true

# ============================================================
# 数据源配置
# ============================================================
# AkShare（免费，无需 key）
# AkTools（免费，本项目通过 HTTP 调用本地 AKTools 服务；默认 http://127.0.0.1:8080）
# 启动方式：./.venv/bin/python -m aktools --host 127.0.0.1 --port 8080
AKTOOLS_BASE_URL=http://127.0.0.1:8080
# Tushare（需要 token）
TUSHARE_TOKEN=
# 其他数据源按需配置
EASTMONEY_ENABLED=true
SINA_QUOTE_ENABLED=true

# ============================================================
# 数据库配置
# ============================================================
# 初期使用 SQLite/DuckDB
DATABASE_URL=sqlite:///data/quant_trading.db
# 中期可切换 PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/quant_trading

# ============================================================
# 风控参数
# ============================================================
MAX_SINGLE_STOCK_POSITION=0.15
MAX_SECTOR_POSITION=0.60
MIN_CASH_RATIO=0.20
SINGLE_STOCK_LOSS_WARN=-0.05
SINGLE_STOCK_LOSS_STOP=-0.08
DAILY_LOSS_WARN=-0.02
DAILY_LOSS_STOP=-0.03
MAX_DRAWDOWN_DEFENSE=-0.08
MAX_DRAWDOWN_HALT=-0.12

# ============================================================
# 回测参数
# ============================================================
BACKTEST_COMMISSION_RATE=0.0003
BACKTEST_STAMP_DUTY=0.001
BACKTEST_SLIPPAGE=0.001

# ============================================================
# 券商接口配置（LEVEL_2+ 使用）
# ============================================================
BROKER_ADAPTER=paper
# BROKER_API_KEY=
# BROKER_API_SECRET=
# BROKER_ACCOUNT=

# ============================================================
# 日志配置
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/quant_trading.log

# ============================================================
# 通知配置（可选）
# ============================================================
# NOTIFY_EMAIL=
# NOTIFY_WEBHOOK_URL=

# ============================================================
# DeepSeek API (BugFix Agent)
# ============================================================
# BugFix Agent 需要该 key 才能把 Open Bug 推进到 analyzing/proposed。
# 进入 proposed 后仍需人工审批，审批通过后才会尝试自动改代码和运行测试。
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ============================================================
# LLM / Model Router 配置
# ============================================================
# 统一 LLM 配置（优先级高于 DEEPSEEK_*）
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY_ENV=DEEPSEEK_API_KEY
# AI 开关
ENABLE_AI_RESEARCH_AGENTS=true
ENABLE_LLM_SIGNAL_EXPLANATION=true
ENABLE_LLM_TRADE_DECISION=false

# ============================================================
# Live Data Closed-Loop 配置
# ============================================================
# 数据源优先级（逗号分隔）
LIVE_DATA_PROVIDER_ORDER=eastmoney,akshare,aktools
# 是否允许 Demo 数据回退（live closed-loop 默认 false）
ENABLE_DEMO_FALLBACK_FOR_LIVE_LOOP=false
# 数据失败时是否 fail-closed
DATA_FAIL_CLOSED=true
# 东方财富 HTTP 超时（秒）
EASTMONEY_TIMEOUT_SECONDS=8.0
# 东方财富请求间隔（秒）
EASTMONEY_REQUEST_INTERVAL=0.8

# ============================================================
# 搜索增强配置（按架构文档 §5.8 / §8）
# ============================================================
# 搜索 Provider 优先级（逗号分隔，支持 tavily/anysearch/firecrawl）
SEARCH_PROVIDER_ORDER=tavily,anysearch,firecrawl
# 每日搜索预算（免费账号合计上限，需预留安全余量）
SEARCH_DAILY_CALL_BUDGET=2500
# Tavily API Key（https://tavily.com 注册获取）
TAVILY_API_KEY=
# AnySearch API Key（https://anysearch.com 注册获取）
ANYSEARCH_API_KEY=
# Firecrawl API Key（https://firecrawl.dev 注册获取）
FIRECRAWL_API_KEY=
